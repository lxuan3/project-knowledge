#!/usr/bin/env node

import path from "node:path";
import { fileURLToPath } from "node:url";

import { loadConfig, resolveProjectRoot } from "../src/config/load.mjs";
import { isAllowedConfigKey, setConfigValue } from "../src/config/manage.mjs";
import { buildIndexes } from "../src/index/build.mjs";
import { buildContextPack } from "../src/search/context-pack.mjs";
import { searchIndex } from "../src/search/search.mjs";
import { createProjectKnowledgeServer } from "../src/server/http.mjs";
import { lintProject } from "../src/lint/lint.mjs";
import { writeProjectNote } from "../src/commands/write.mjs";
import { listProjects } from "../src/vault/projects.mjs";

const commands = ["write", "index", "list-projects", "search", "context-pack", "config", "serve", "lint", "print-agent-guidance"];

const helpText = [
  "project-knowledge",
  "",
  "Usage:",
  "  project-knowledge <command>",
  "",
  "Commands:",
  ...commands.map((command) => `  ${command}`)
].join("\n");

const agentGuidanceText = [
  "### Project Knowledge",
  "",
  "- If a task touches an existing project, prior decisions, architecture background, or a runbook, use `project-knowledge` before assuming history.",
  "- Do not assume project history before running either `search` or `context-pack`.",
  "- Use `search` for simple, targeted questions.",
  "- Use `context-pack` for complex or unfamiliar tasks that need broader project context.",
  "- Obsidian markdown is the source of truth. Do not treat the index as canonical memory."
].join("\n");

function readFlag(flagName) {
  const index = process.argv.indexOf(flagName);
  if (index === -1) return null;
  return process.argv[index + 1] ?? null;
}

async function main() {
  const arg = process.argv[2];
  const repoRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..");
  const config = await loadConfig();

  if (!arg || arg === "--help" || arg === "-h") {
    process.stdout.write(`${helpText}\n`);
    return;
  }

  if (!commands.includes(arg)) {
    process.stderr.write(`Unknown command: ${arg}\n`);
    process.stderr.write(`${helpText}\n`);
    process.exitCode = 1;
    return;
  }

  if (arg === "index") {
    const vaultRoot = readFlag("--vault-root") ?? config.vaultRoot;
    const indexRoot = readFlag("--index-root") ?? config.indexRoot;
    const retrievalBackend = readFlag("--retrieval-backend") ?? config.retrievalBackend;
    const lancedbUri = readFlag("--lancedb-uri") ?? config.lancedbUri;
    await buildIndexes({ vaultRoot, indexRoot, retrievalBackend, lancedbUri });
    process.stdout.write(`Indexed vault: ${vaultRoot}\n`);
    return;
  }

  if (arg === "print-agent-guidance") {
    process.stdout.write(`${agentGuidanceText}\n`);
    return;
  }

  if (arg === "list-projects") {
    const vaultRoot = readFlag("--vault-root") ?? config.vaultRoot;
    const projects = await listProjects(vaultRoot);
    process.stdout.write(`${JSON.stringify({ vaultRoot, projects }, null, 2)}\n`);
    return;
  }

  if (arg === "search") {
    const indexRoot = readFlag("--index-root") ?? config.indexRoot;
    const query = readFlag("--query");
    const project = readFlag("--project");
    const scope = readFlag("--scope") ?? (project ? "project" : "global");
    const retrievalBackend = readFlag("--retrieval-backend") ?? config.retrievalBackend;
    const lancedbUri = readFlag("--lancedb-uri") ?? config.lancedbUri;
    const remoteBaseUrl = readFlag("--remote-base-url") ?? config.remoteBaseUrl;
    const remotePrimaryUrl = readFlag("--remote-primary-url") ?? config.remotePrimaryUrl;
    const remoteBackupUrl = readFlag("--remote-backup-url") ?? config.remoteBackupUrl;
    if (!query) {
      process.stderr.write("search requires --index-root and --query\n");
      process.exitCode = 1;
      return;
    }
    const result = await searchIndex({
      indexRoot,
      query,
      project,
      scope,
      retrievalBackend,
      lancedbUri,
      remoteBaseUrl,
      remotePrimaryUrl,
      remoteBackupUrl
    });
    process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
    return;
  }

  if (arg === "context-pack") {
    const indexRoot = readFlag("--index-root") ?? config.indexRoot;
    const project = readFlag("--project");
    const query = readFlag("--query");
    const retrievalBackend = readFlag("--retrieval-backend") ?? config.retrievalBackend;
    const lancedbUri = readFlag("--lancedb-uri") ?? config.lancedbUri;
    const remoteBaseUrl = readFlag("--remote-base-url") ?? config.remoteBaseUrl;
    const remotePrimaryUrl = readFlag("--remote-primary-url") ?? config.remotePrimaryUrl;
    const remoteBackupUrl = readFlag("--remote-backup-url") ?? config.remoteBackupUrl;
    if (!project) {
      process.stderr.write("context-pack requires --project\n");
      process.exitCode = 1;
      return;
    }
    const result = await buildContextPack({
      indexRoot,
      project,
      query,
      retrievalBackend,
      lancedbUri,
      remoteBaseUrl,
      remotePrimaryUrl,
      remoteBackupUrl
    });
    process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
    return;
  }

  if (arg === "serve") {
    const host = readFlag("--host") ?? "127.0.0.1";
    const port = Number(readFlag("--port") ?? "7357");
    const server = createProjectKnowledgeServer({ config });
    await new Promise((resolve) => server.listen(port, host, resolve));
    process.stdout.write(`Project knowledge server listening on http://${host}:${port}\n`);
    return;
  }

  if (arg === "config") {
    const action = process.argv[3];

    if (action === "get") {
      process.stdout.write(`${JSON.stringify(config, null, 2)}\n`);
      return;
    }

    if (action === "set") {
      const key = process.argv[4];
      const value = process.argv[5];

      if (!key || value == null) {
        process.stderr.write("config set requires <key> <value>\n");
        process.exitCode = 1;
        return;
      }

      if (!isAllowedConfigKey(key)) {
        process.stderr.write(`Unsupported config key: ${key}\n`);
        process.exitCode = 1;
        return;
      }

      const next = await setConfigValue({ key, value });
      process.stdout.write(`${JSON.stringify(next, null, 2)}\n`);
      return;
    }

    process.stderr.write("config requires get or set\n");
    process.exitCode = 1;
    return;
  }

  if (arg === "lint") {
    const projectRoot = resolveProjectRoot({
      config,
      projectRoot: readFlag("--project-root"),
      project: readFlag("--project")
    });
    if (!projectRoot) {
      process.stderr.write("lint requires --project-root or --project\n");
      process.exitCode = 1;
      return;
    }
    const result = await lintProject(projectRoot);
    process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
    process.exitCode = result.ok ? 0 : 1;
    return;
  }

  if (arg === "write") {
    const project = readFlag("--project");
    const projectRoot = resolveProjectRoot({
      config,
      projectRoot: readFlag("--project-root"),
      project
    });
    const docType = readFlag("--doc-type");
    const slug = readFlag("--slug");
    const title = readFlag("--title");
    if (!projectRoot || !project || !docType || (!slug && !title)) {
      process.stderr.write("write requires --project --doc-type and either --slug or --title, with optional --project-root override\n");
      process.exitCode = 1;
      return;
    }
    const createdPath = await writeProjectNote({
      repoRoot,
      projectRoot,
      project,
      docType,
      slug,
      title
    });
    process.stdout.write(`${createdPath}\n`);
  }
}

try {
  await main();
} catch (error) {
  process.stderr.write(`${error?.message ?? String(error)}\n`);
  process.exit(1);
}
