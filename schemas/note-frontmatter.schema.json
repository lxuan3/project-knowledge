{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["project", "doc_type", "status"],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "doc_type": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "archived"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
